<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

    <%- include('partials/header') %>

    <main>
        <h2> <%= project.title %></h2>
        <ul>
            <li>
                <strong>Description:</strong> <%= project.description %>
            </li>
            <li>
                <strong>Date:</strong> <%= project.project_date %>
            </li>
            <li>
                <strong>Location:</strong> <%= project.location %>
            </li>
            <li>
                <strong>Organization:</strong> 
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
            </li>
            <!-- NUEVO BLOQUE PARA CATEGORÍAS -->
            <li>
                <strong>Categories:</strong>
                <ul>
                    <% if (project.categories && project.categories.length) { %>
                        <% project.categories.forEach(category => { %>
                            <li>
                                <a href="/category/<%= category.category_id %>">
                                    <%= category.category_name %>
                                </a>
                            </li>
                        <% }); %>
                    <% } else { %>
                        <li>No categories assigned</li>
                    <% } %>
                </ul>
            </li>
        </ul>
    
    </main>

    <%- include('partials/footer') %>

</body>
</html>